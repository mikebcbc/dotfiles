[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-i": "workspace::ToggleRightDock",
      "alt-cmd-s": "workspace::ToggleLeftDock",
      "cmd-t cmd-f": "terminal_panel::Toggle",
      "cmd-alt-t": "terminal_panel::Toggle",
      "cmd-p": "file_finder::Toggle",
      "cmd-p f": "workspace::ToggleZoom",
      "cmd-k cmd-down": null,
      "cmd-k cmd-left": null,
      "cmd-k cmd-m": null,
      "cmd-k cmd-right": null,
      "cmd-k cmd-s": null,
      "cmd-k cmd-shift-t": null,
      "cmd-k cmd-t": null,
      "cmd-k cmd-up": null,
      "cmd-k m": null,
      "cmd-k n": null,
      "cmd-k s": null,
      "cmd-k shift-down": null,
      "cmd-k shift-left": null,
      "cmd-k shift-right": null,
      "cmd-k shift-up": null
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-u": [
        "terminal::SendKeystroke",
        "pageup"
      ],
      "ctrl-d": [
        "terminal::SendKeystroke",
        "pagedown"
      ],
      "cmd-p f": "workspace::ToggleZoom",
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-j": "workspace::ActivatePaneDown",
      "cmd-k": "workspace::ActivatePaneUp",
      "cmd-l": "workspace::ActivatePaneRight",
      "cmd-shift-h": "vim::ResizePaneRight",
      "cmd-shift-j": "vim::ResizePaneDown",
      "cmd-shift-k": "vim::ResizePaneUp",
      "cmd-shift-l": "vim::ResizePaneLeft",
      "cmd-t h": "pane::SplitLeft",
      "cmd-t j": "pane::SplitDown",
      "cmd-t k": "pane::SplitUp",
      "cmd-t l": "pane::SplitRight"
    }
  },
  {
    "context": "AgentPanel > Terminal",
    "bindings": {
      "ctrl-u": [
        "terminal::SendKeystroke",
        "pageup"
      ],
      "ctrl-d": [
        "terminal::SendKeystroke",
        "pagedown"
      ],
      "cmd-p f": "workspace::ToggleZoom",
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-j": "workspace::ActivatePaneDown",
      "cmd-k": "workspace::ActivatePaneUp",
      "cmd-l": "workspace::ActivatePaneRight",
      "cmd-shift-h": "vim::ResizePaneRight",
      "cmd-shift-j": "vim::ResizePaneDown",
      "cmd-shift-k": "vim::ResizePaneUp",
      "cmd-shift-l": "vim::ResizePaneLeft",
      "cmd-t h": "pane::SplitLeft",
      "cmd-t j": "pane::SplitDown",
      "cmd-t k": "pane::SplitUp",
      "cmd-t l": "pane::SplitRight"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "alt-left": "workspace::ActivatePaneLeft",
      "alt-down": "workspace::ActivatePaneDown",
      "alt-up": "workspace::ActivatePaneUp",
      "alt-right": "workspace::ActivatePaneRight",
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-j": "workspace::ActivatePaneDown",
      "cmd-k": "workspace::ActivatePaneUp",
      "cmd-l": "workspace::ActivatePaneRight",
      "cmd-shift-h": "vim::ResizePaneRight",
      "cmd-shift-j": "vim::ResizePaneDown",
      "cmd-shift-k": "vim::ResizePaneUp",
      "cmd-shift-l": "vim::ResizePaneLeft"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space": [
        "action::Sequence",
        [
          "project_panel::Open",
          "project_panel::Toggle"
        ]
      ]
    }
  },
  {
    "context": "Workspace && !Terminal",
    "bindings": {
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-j": "workspace::ActivatePaneDown",
      "cmd-k": "workspace::ActivatePaneUp",
      "cmd-l": "workspace::ActivatePaneRight",
      "cmd-shift-h": "vim::ResizePaneRight",
      "cmd-shift-j": "vim::ResizePaneDown",
      "cmd-shift-k": "vim::ResizePaneUp",
      "cmd-shift-l": "vim::ResizePaneLeft",
      "cmd-p h": "pane::SplitLeft",
      "cmd-p j": "pane::SplitDown",
      "cmd-p k": "pane::SplitUp",
      "cmd-p l": "pane::SplitRight",
      "cmd-p n": "pane::SplitRight",
      "cmd-p d": "pane::SplitDown",
      "cmd-t h": [
        "action::Sequence",
        [
          [
            "pane::SplitLeft",
            {
              "mode": "EmptyPane"
            }
          ],
          "workspace::NewCenterTerminal"
        ]
      ],
      "cmd-t j": [
        "action::Sequence",
        [
          [
            "pane::SplitDown",
            {
              "mode": "EmptyPane"
            }
          ],
          "workspace::NewCenterTerminal"
        ]
      ],
      "cmd-t k": [
        "action::Sequence",
        [
          [
            "pane::SplitUp",
            {
              "mode": "EmptyPane"
            }
          ],
          "workspace::NewCenterTerminal"
        ]
      ],
      "cmd-t l": [
        "action::Sequence",
        [
          [
            "pane::SplitRight",
            {
              "mode": "EmptyPane"
            }
          ],
          "workspace::NewCenterTerminal"
        ]
      ]
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-k cmd-/": null,
      "cmd-k cmd-0": null,
      "cmd-k cmd-1": null,
      "cmd-k cmd-2": null,
      "cmd-k cmd-3": null,
      "cmd-k cmd-4": null,
      "cmd-k cmd-5": null,
      "cmd-k cmd-6": null,
      "cmd-k cmd-7": null,
      "cmd-k cmd-8": null,
      "cmd-k cmd-9": null,
      "cmd-k cmd-[": null,
      "cmd-k cmd-b": null,
      "cmd-k cmd-d": null,
      "cmd-k cmd-i": null,
      "cmd-k cmd-j": null,
      "cmd-k cmd-l": null,
      "cmd-k cmd-q": null,
      "cmd-k cmd-]": null,
      "cmd-k ctrl-cmd-d": null,
      "cmd-k p": null,
      "cmd-k q": null,
      "cmd-k r": null,
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-j": "workspace::ActivatePaneDown",
      "cmd-k": "workspace::ActivatePaneUp",
      "cmd-l": "workspace::ActivatePaneRight",
      "cmd-shift-h": "vim::ResizePaneRight",
      "cmd-shift-j": "vim::ResizePaneDown",
      "cmd-shift-k": "vim::ResizePaneUp",
      "cmd-shift-l": "vim::ResizePaneLeft"
    }
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "cmd-k z": null
    }
  },
  {
    "context": "Editor && extension == md",
    "bindings": {
      "cmd-k v": null
    }
  },
  {
    "context": "Editor && extension == svg",
    "bindings": {
      "cmd-k v": null
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-k cmd-w": null,
      "cmd-k down": null,
      "cmd-k e": null,
      "cmd-k left": null,
      "cmd-k right": null,
      "cmd-k shift-enter": null,
      "cmd-k t": null,
      "cmd-k u": null,
      "cmd-k up": null,
      "cmd-k w": null
    }
  },
  {
    "context": "FileFinder || (FileFinder > Picker > Editor) || (FileFinder > Picker > menu)",
    "bindings": {
      "cmd-k": null
    }
  },
  {
    "context": "RecentProjects || (RecentProjects > Picker > Editor)",
    "bindings": {
      "cmd-k": null
    }
  },
  {
    "context": "Editor && VimControl && vim_mode == normal",
    "bindings": {
      "space": null,
      "alt-left": "workspace::ActivatePaneLeft",
      "alt-down": "workspace::ActivatePaneDown",
      "alt-up": "workspace::ActivatePaneUp",
      "alt-right": "workspace::ActivatePaneRight",
      "space c": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ],
      "space e": "project_panel::Toggle",
      "space g g": [
        "task::Spawn",
        {
          "task_name": "start lazygit",
          "reveal_target": "center"
        }
      ],
      "space f k": "zed::OpenKeymap",
      "space f shift-c": "command_palette::Toggle",
      "space f f": [
        "task::Spawn",
        {
          "task_name": "Find Files (tv)",
          "reveal_target": "center"
        }
      ],
      "space f F": [
        "task::Spawn",
        {
          "task_name": "Find Files — hidden (tv)",
          "reveal_target": "center"
        }
      ],
      "space f s": "task::Spawn",
      "space f c": [
        "task::Spawn",
        {
          "task_name": "Find Selection in Files (tv)",
          "reveal_target": "center"
        }
      ],
      "space f w": [
        "task::Spawn",
        {
          "task_name": "Find in Files (tv)",
          "reveal_target": "center"
        }
      ],
      "space f d": "diagnostics::Deploy",
      "space f .": [
        "projects::OpenRecent",
        {
          "create_new_window": false
        }
      ],
      "space f q": "project_search::ToggleFocus",
      "space f space": "tab_switcher::Toggle",
      "space l s": "outline_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor && VimControl && vim_mode == insert",
    "bindings": {
      "space e": "project_panel::Toggle"
    }
  },
  {
    "bindings": {
      "cmd-f": [
        "task::Spawn",
        {
          "task_name": "Find in Files (tv)",
          "reveal_target": "center"
        }
      ]
    }
  }
]
