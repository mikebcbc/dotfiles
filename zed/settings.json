// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "favorite_models": [],
    "model_parameters": [],
    "tool_permissions": {
      "default": "allow",
      "tools": {}
    }
  },
  "cli_default_open_behavior": "existing_window",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  // With project_panel::Toggle on ctrl-e: when focus leaves the file tree, close that panel only
  // (does not toggle the whole left dock / agent strip). space e: Yazi from worktree root; space shift-e (space E): Yazi from the current file's directory (center terminal).
  "close_panel_on_toggle": true,
  "agent_servers": {
    "cursor": {
      "type": "registry"
    }
  },
  "icon_theme": "Catppuccin Macchiato",
  "buffer_font_family": "Inconsolata Nerd Font",
  "buffer_font_size": 14,
  "buffer_font_features": {
    "calt": false,
    "liga": false,
    "dlig": false
  },
  "ui_font_size": 14,
  "tab_size": 3,
  "hard_tabs": false,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato",
  },
}
